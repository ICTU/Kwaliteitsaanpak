{
  "BuildPath": "build/ToolGids/",
  "Title": "ICTU Toolgids - ZAP",
  "Subtitle": "Handleidingen en tips bij het gebruik van tools die softwarekwaliteit inzichtelijk maken.",
  "DocumentType": "Kwaliteitsaanpak",
  "FrontPage": "ICTU",
  "OutputFormats": {
    "html": {
      "IncludeTableOfContents": true,
      "InputFile": "Content/ToolGids/ToolGids.md",
      "OutputFile": "ICTU-ToolGids.html",
      "OutputPaths": ["docs/$VERSIE$"],
      "CopyFiles": [
        {
          "from": "DocumentDefinitions/Shared/document.css",
          "to": "docs/$VERSIE$/ICTU-ToolGids.css"
        },
        {
          "from": "Content/ToolGids/Images/*.png",
          "to": "docs/$VERSIE$/ToolGids/Images"
        },
        {
          "from": "Content/Images/*.png",
          "to": "docs/$VERSIE$"
        }
      ]
    }
  },
  "VariablesFiles": ["DocumentDefinitions/Shared/variables.json", "DocumentDefinitions/Shared/variables-toolgids.json"]
}
